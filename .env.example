# HTTP
NODE_ENV=development
APP_ROLE=api
HOST=0.0.0.0
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4200,http://127.0.0.1:4200
FRONTEND_URL=http://localhost:5173
TRUST_PROXY=false
LOG_LEVEL=http
LOG_FORMAT=pretty
REQUEST_BODY_LIMIT=1mb
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300

# Optional infrastructure
# The API can start without these values. Configure them when a module uses
# PostgreSQL, Redis, Meilisearch or JWT authentication.
DATABASE_URL=postgresql://ttk_admin:change-me@localhost:5432/ttk_db
REDIS_URL=redis://:change-me@localhost:6379
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=change-me-with-at-least-16-characters
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET_PREFIX=ttk
STORAGE_ACCESS_KEY=ttk_storage
STORAGE_SECRET_KEY=change-me-storage-password
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_MAX_VIDEO_SIZE_MB=100
JWT_SECRET=change-me-with-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
BCRYPT_ROUNDS=12
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Transactional email worker
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=TTK Services
MAIL_BRAND_NAME=TTK Services
MAIL_LOGO_URL=
MAIL_SUPPORT_EMAIL=support@example.com
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Administrateur TTK
ADMIN_PASSWORD=change-me-admin-password

# Docker Compose infrastructure
DB_USER=ttk_admin
DB_PASSWORD=change-me
DB_NAME=ttk_db
DB_PORT=55432
REDIS_PORT=6379
MEILI_PORT=7700
STORAGE_PORT=9000
STORAGE_CONSOLE_PORT=9001
