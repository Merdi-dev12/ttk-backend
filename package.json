{
  "name": "ttk-backend",
  "version": "1.0.0",
  "description": "Backend monolithique modulaire pour TTK",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/core/database/migrate.ts",
    "db:migrate:docker": "docker compose exec api npm run db:migrate",
    "admin:create": "tsx src/modules/users/createAdmin.ts",
    "admin:create:docker": "docker compose exec api npm run admin:create",
    "worker:email": "tsx watch src/core/queues/email.worker.ts",
    "worker:search": "tsx watch src/core/queues/search.worker.ts",
    "search:reindex": "tsx src/core/search/reindex.ts",
    "search:reindex:docker": "docker compose exec api npm run search:reindex",
    "infra:up": "docker compose up --build -d --wait",
    "infra:down": "docker compose down --remove-orphans"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-list-endpoints": "^7.1.1",
    "express-rate-limit": "^8.4.1",
    "file-type": "^21.3.4",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.58.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
